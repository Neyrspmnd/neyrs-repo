{
  "name": "@neyrs/core",
  "version": "0.1.0",
  "description": "AI-powered conversational agent for Solana wallet operations, DeFi interactions, and Web3 commerce",
  "keywords": [
    "solana",
    "defi",
    "ai-agent",
    "chatbot",
    "wallet",
    "swap",
    "stake",
    "web3",
    "commerce"
  ],
  "homepage": "https://github.com/neyrs/neyrs-core#readme",
  "bugs": {
    "url": "https://github.com/neyrs/neyrs-core/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neyrs/neyrs-core.git"
  },
  "license": "MIT",
  "author": {
    "name": "Neyrs Protocol",
    "email": "dev@neyrs.app"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "bench": "tsx benchmarks/agent-benchmark.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@solana/web3.js": "^1.87.6",
    "axios": "^1.6.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "@vitest/coverage-v8": "^1.0.4",
    "eslint": "^8.55.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.1.1",
    "tsup": "^8.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
